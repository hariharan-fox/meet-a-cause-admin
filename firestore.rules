
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Admin Rules ---
    match /admins/{adminId} {
      // Allow any signed-in user to read admin profiles (necessary for portal access and team view)
      allow read: if isSignedIn();
      
      // Allow a user to create their own admin profile during signup
      allow create: if isOwner(adminId);
      
      // Only the owner or an existing admin can update/delete
      allow update, delete: if isOwner(adminId) || isAdmin();
    }

    // --- Volunteer Profile Rules ---
    match /volunteer_profiles/{volunteerId} {
      allow get: if isOwner(volunteerId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(volunteerId);
      allow update, delete: if isOwner(volunteerId) || isAdmin();
    }

    // --- NGO Profile Rules ---
    match /ngo_profiles/{ngoId} {
      allow get: if isOwner(ngoId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(ngoId);
      allow update, delete: if isOwner(ngoId) || isAdmin();
    }

    // --- Event Rules ---
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ngoId == request.auth.uid);
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.ngoId == request.auth.uid);
    }
  }
}
