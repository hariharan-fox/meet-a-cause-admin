rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin Rules ---
    // In the Admin Portal, we allow authenticated users to read and write admin profiles
    // to facilitate team management and initial setup.
    match /admins/{adminId} {
      allow read, write: if isSignedIn();
    }

    // --- Volunteer Profile Rules ---
    // Allow listing and management for authenticated admin portal users.
    match /volunteer_profiles/{volunteerId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- NGO Profile Rules ---
    // Allow listing and management for authenticated admin portal users.
    match /ngo_profiles/{ngoId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Event Rules ---
    // Events are globally readable, but modifications require authentication.
    match /events/{eventId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }
  }
}