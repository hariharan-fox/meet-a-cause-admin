{
  "entities": {
    "VolunteerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VolunteerProfile",
      "type": "object",
      "description": "Shared volunteer profile used by both Admin and User apps.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "pending", "verified", "rejected"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email"]
    },
    "NGOProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "NGOProfile",
      "type": "object",
      "description": "Shared NGO profile managed by Admin app.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mission": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "pending", "verified", "rejected"] },
        "darpanId": { "type": "string" },
        "panNumber": { "type": "string" }
      },
      "required": ["id", "name", "verificationStatus"]
    },
    "AdminProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminProfile",
      "type": "object",
      "description": "Administrator profile for the management portal.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "moderator", "viewer"] }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Shared event data visible to users and moderated by admins.",
      "properties": {
        "id": { "type": "string" },
        "ngoId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "cancelled"] }
      },
      "required": ["id", "ngoId", "title", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/backend/entities/AdminProfile" },
      "description": "Administrator profiles for the portal."
    },
    "/volunteer_profiles/{volunteerId}": {
      "schema": { "$ref": "#/backend/entities/VolunteerProfile" },
      "description": "Private volunteer profiles."
    },
    "/ngo_profiles/{ngoId}": {
      "schema": { "$ref": "#/backend/entities/NGOProfile" },
      "description": "Private NGO profiles."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/backend/entities/Event" },
      "description": "Global event collection."
    }
  }
}
